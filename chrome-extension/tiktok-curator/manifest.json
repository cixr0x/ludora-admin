{
  "manifest_version": 3,
  "name": "Ludora TikTok Curator",
  "version": "0.1.0",
  "description": "Speeds up Ludora TikTok tutorial curation from TikTok search and video pages.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:4001/*",
    "http://localhost:4001/*",
    "https://www.tiktok.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tiktok.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Ludora TikTok Curator"
  }
}
